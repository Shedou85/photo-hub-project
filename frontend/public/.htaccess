<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect www to non-www (canonical domain)
  RewriteCond %{HTTP_HOST} ^www\.pixelforge\.pro [NC]
  RewriteRule ^(.*)$ https://pixelforge.pro/$1 [R=301,L]

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://pixelforge.pro/$1 [R=301,L]

  # Static files — serve directly
  RewriteRule ^sitemap\.xml$ - [L]
  RewriteRule ^robots\.txt$ - [L]

  # If file or directory exists — serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else — React SPA
  RewriteRule ^ index.html [L]
</IfModule>

# CORS headers
<IfModule mod_headers.c>
  Header set Access-Control-Allow-Origin "https://pixelforge.pro"
  Header set Access-Control-Allow-Headers "Authorization, Content-Type"
  Header set Access-Control-Allow-Methods "GET, POST, OPTIONS"
</IfModule>

# Correct Content-Type for XML files
<IfModule mod_mime.c>
  AddType application/xml .xml
</IfModule>
